{
  "name": "vscode-loom",
  "displayName": "Loom Language",
  "description": "Provides syntax highlighting and code snippets for the Loom programming language for Roblox.",
  "version": "0.1.0",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.7.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "url": "https://github.com/R-unic/loom"
  },
  "contributes": {
    "languages": [
      {
        "id": "loom",
        "aliases": [
          "Loom",
          "loom"
        ],
        "extensions": [
          ".loom"
        ],
        "icon": {
          "light": "./assets/icon.png",
          "dark": "./assets/icon.png"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "loom",
        "scopeName": "source.loom",
        "path": "./syntaxes/loom.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "loom",
        "path": "./snippets/loom.json"
      }
    ]
  }
}