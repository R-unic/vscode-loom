{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Loom",
  "fileTypes": [
    "loom"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#enums"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numerics"
    },
    {
      "include": "#object-types"
    },
    {
      "include": "#type-aliases"
    },
    {
      "include": "#functions-events"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#function-calls"
    },
    {
      "include": "#identifiers"
    },
    {
      "include": "#constants"
    }
  ],
  "repository": {
    "constants": {
      "patterns": [
        {
          "name": "constant.other.loom",
          "match": "\\b([A-Z][A-Z0-9_]*)\\b"
        }
      ]
    },
    "type": {
      "patterns": [
        {
          "include": "#primitive-types"
        },
        {
          "include": "#generic-type"
        },
        {
          "include": "#object-types"
        },
        {
          "include": "#default-expression"
        }
      ]
    },
    "primitive-types": {
      "match": "\\b(number|string|bool|never|unknown|void|none)\\b",
      "name": "keyword.type.loom"
    },
    "enums": {
      "patterns": [
        {
          "begin": "\\b(enum)\\s+([A-Z][A-Za-z0-9_]*)\\s*(\\{)",
          "beginCaptures": {
            "1": {
              "name": "keyword.loom"
            },
            "2": {
              "name": "entity.name.type.enum.loom"
            },
            "3": {
              "name": "punctuation.bracket.loom"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.bracket.loom"
            }
          },
          "patterns": [
            {
              "name": "variable.other.enummember.loom",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
            },
            {
              "match": ",",
              "name": "punctuation.separator.delimiter.loom"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#numerics"
            }
          ]
        }
      ]
    },
    "generic-type": {
      "begin": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(<)",
      "beginCaptures": {
        "1": {
          "name": "entity.name.type.loom"
        },
        "2": {
          "name": "punctuation.bracket.angle.loom"
        }
      },
      "end": ">",
      "endCaptures": {
        "0": {
          "name": "punctuation.bracket.angle.loom"
        }
      },
      "patterns": [
        {
          "include": "#generics"
        }
      ]
    },
    "default-expression": {
      "patterns": [
        {
          "include": "#numerics"
        },
        {
          "include": "#strings"
        },
        {
          "match": "\\b(true|false)\\b",
          "name": "constant.language.boolean.loom"
        },
        {
          "match": "\\b(none)\\b",
          "name": "constant.language.none.loom"
        },
        {
          "match": "[a-zA-Z_][a-zA-Z0-9_]*",
          "name": "variable.other.loom"
        }
      ]
    },
    "generics": {
      "begin": "\\s*<",
      "beginCaptures": {
        "0": {
          "name": "punctuation.bracket.angle.loom"
        }
      },
      "end": ">",
      "endCaptures": {
        "0": {
          "name": "punctuation.bracket.angle.loom"
        }
      },
      "patterns": [
        {
          "name": "meta.type-parameter.loom",
          "begin": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "beginCaptures": {
            "1": {
              "name": "entity.name.type.loom"
            }
          },
          "end": "(?=\\s*(,|>))",
          "patterns": [
            {
              "begin": "\\s*:\\s*",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.separator.constraint.loom"
                }
              },
              "end": "(?=\\s*(,|=|>))",
              "patterns": [
                {
                  "include": "#type"
                }
              ]
            },
            {
              "begin": "\\s*=\\s*",
              "beginCaptures": {
                "0": {
                  "name": "keyword.operator.assignment.loom"
                }
              },
              "end": "(?=\\s*(,|>))",
              "patterns": [
                {
                  "include": "#default-expression"
                }
              ]
            }
          ]
        },
        {
          "match": ",",
          "name": "punctuation.separator.delimiter.loom"
        },
        {
          "include": "#generics"
        }
      ]
    },
    "object-types": {
      "patterns": [
        {
          "name": "entity.name.type.loom",
          "match": "(\\.?)\\b[A-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-hash.loom",
          "match": "##.*$"
        },
        {
          "name": "comment.block",
          "begin": "#:",
          "end": ":#"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.loom",
          "match": "\\b(if|else|while|for|after|every|defer|break|continue|return|defer)\\b"
        },
        {
          "name": "keyword.control.loom",
          "match": "\\b(fn|event)\\b(?!\\s+[_a-zA-Z][_a-zA-Z0-9]*)"
        },
        {
          "name": "keyword.loom",
          "match": "\\b(declare|nameof|keyof|typeof|enum|type|implement|interface|trait|as|let|mut|new)\\b"
        },
        {
          "include": "#primitive-types"
        },
        {
          "name": "keyword.other.loom",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "entity.name.tag.loom",
          "match": "\\b(none)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.loom",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.loom"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.loom"
            }
          },
          "patterns": [
            {
              "name": "meta.interpolation.loom",
              "begin": "#\\{",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.begin.loom"
                }
              },
              "end": "\\}",
              "endCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.end.loom"
                }
              },
              "patterns": [
                {
                  "include": "$self"
                }
              ]
            },
            {
              "match": "\\\\.",
              "name": "constant.character.escape.loom"
            }
          ]
        },
        {
          "name": "string.quoted.single.loom",
          "begin": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.loom"
            }
          },
          "end": "'",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.loom"
            }
          },
          "patterns": [
            {
              "name": "meta.interpolation.loom",
              "begin": "#\\{",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.begin.loom"
                }
              },
              "end": "\\}",
              "endCaptures": {
                "0": {
                  "name": "punctuation.section.interpolation.end.loom"
                }
              },
              "patterns": [
                {
                  "include": "$self"
                }
              ]
            },
            {
              "match": "\\\\.",
              "name": "constant.character.escape.loom"
            }
          ]
        }
      ]
    },
    "numerics": {
      "name": "constant.numeric.loom",
      "patterns": [
        {
          "name": "constant.numeric.loom",
          "match": "\\b(0[bB][01_]+|0[xX][0-9a-fA-F_]+|0[oO][0-7_]+|(\\d|_)+(\\.(\\d|_)+)?([eE][\\+\\-]?\\d+)?[hH]?[mM]?[sS]?[mMsS]?[hHzZs]?)\\b"
        }
      ]
    },
    "type-aliases": {
      "patterns": [
        {
          "name": "meta.typealias.loom",
          "begin": "\\b(type)\\s+([_a-zA-Z][_a-zA-Z0-9]*)\\<?",
          "beginCaptures": {
            "1": {
              "name": "keyword.loom"
            },
            "2": {
              "name": "entity.name.type.loom"
            }
          },
          "end": "(?=\\s*)",
          "patterns": [
            {
              "include": "#generics"
            },
            {
              "include": "#type"
            }
          ]
        }
      ]
    },
    "functions-events": {
      "patterns": [
        {
          "name": "meta.function.loom",
          "begin": "\\b(fn|event)\\s+([_a-zA-Z][_a-zA-Z0-9]*)",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.loom"
            },
            "2": {
              "name": "entity.name.function.loom"
            }
          },
          "end": "(?=\\s*[\\-\\>|\\{|\\;||\n])",
          "patterns": [
            {
              "include": "#generics"
            },
            {
              "include": "#type"
            }
          ]
        },
        {
          "name": "support.function.loom",
          "match": "\\b(print)\\b"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "meta.function-call.loom",
          "match": "\\b([_a-zA-Z][_a-zA-Z0-9]*)\\s*\\!?\\(",
          "captures": {
            "1": {
              "name": "entity.name.function.loom"
            }
          }
        },
        {
          "name": "meta.function-call.loom",
          "match": "\\b([_a-zA-Z][_a-zA-Z0-9]*)\\s*\\::<",
          "captures": {
            "1": {
              "name": "entity.name.function.loom"
            }
          },
          "patterns": [
            {
              "include": "#generics"
            },
            {
              "include": "#type"
            }
          ]
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "[\\[\\]\\(\\)\\{\\}]",
          "name": "punctuation.bracket.loom"
        },
        {
          "name": "variable.other.loom",
          "match": "\\b([_a-zA-Z][_a-zA-Z0-9_]*)\\b"
        },
        {
          "match": "\\;",
          "name": "punctuation.separator.semicolon.loom"
        },
        {
          "match": "\\.",
          "name": "punctuation.accessor.dot.loom"
        },
        {
          "match": "(\\-|\\+|\\*|\\/\\/|\\/|\\^|\\%|\\~|\\&|\\|)",
          "name": "keyword.operator.arithmetic.loom"
        },
        {
          "match": "(=|-=|\\+=|\\*=|\\/=|\\^=|\\%=|\\~=|\\&=|\\|=|<<=|>>=|>>>=|&&=|\\|\\|=|\\?\\?=|//=|//)",
          "name": "keyword.operator.assignment.loom"
        },
        {
          "match": "(==|<=|>=|!=|<|>|<=|>=)",
          "name": "keyword.operator.comparison.loom"
        },
        {
          "match": "(!|&&|\\|\\||\\?|\\:|\\.\\.)",
          "name": "keyword.operator.logical.loom"
        },
        {
          "match": "(::<)",
          "name": "keyword.operator.special.loom"
        }
      ]
    }
  },
  "scopeName": "source.loom"
}