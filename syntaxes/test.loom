enum Job {
  Unemployed,
  Doctor,
  Lawyer = 69,
  Engineer,
  Teacher,
  Programmer,
  AZ,
  A
}

interface HasName {
  name: string;
}

interface HasAge {
  age: number;
}

interface Person<J: Job>: HasName, HasAge {
  job: J;
  ssn: number;
}

#:
interface Runic {
  name: string;
  age: number;
  job: Job.Programmer;
  ssn: number;
}
:#
type Runic = Person<Job.Programmer>;

let x = 69;
mut y = 420;