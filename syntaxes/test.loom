enum Syntax {
  Plus, Minus,
  Star, Slash
}

interface SyntaxMap {
  [string]: Syntax;
}

let keyword_map = new SyntaxMap { ["+"]: Syntax.Plus }

interface LexerState {
  source: string;
  mut position: number;
  mut character: number;
  mut line: number;
}

let state = new LexerState {
  source: "+-*/"
  position: 0,
  character: 0,
  line: 1
};

fn advance(state: LexerState) {
  let char = state.source[state.position];
  state.position += 1;
  state.character += 1;

  return char;
}